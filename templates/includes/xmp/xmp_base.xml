{# XMP basis voor PDF-metadata. Wordt door EasyPost/PolApp uitgelezen
   om documenten te indexeren in de archiefoplossing. #}
<x:xmpmeta xmlns:x="adobe:ns:meta/">
  <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
    <rdf:Description rdf:about=""
        xmlns:dc="http://purl.org/dc/elements/1.1/"
        xmlns:xmp="http://ns.adobe.com/xap/1.0/"
        xmlns:pl="https://patronale-life.be/xmp/1.0/">
      <dc:title>
        <rdf:Alt>
          <rdf:li xml:lang="x-default">{{ document_title | default('') }}</rdf:li>
          {% block xmp_title_locales %}{% endblock %}
        </rdf:Alt>
      </dc:title>
      <dc:creator>
        <rdf:Seq>
          <rdf:li>{{ lender.name | default('Patronale Life NV') }}</rdf:li>
        </rdf:Seq>
      </dc:creator>
      <dc:description>
        <rdf:Alt>
          <rdf:li xml:lang="x-default">{{ document_subject | default('') }}</rdf:li>
        </rdf:Alt>
      </dc:description>
      <dc:format>application/pdf</dc:format>
      <xmp:CreateDate>{{ now | format_datetime }}</xmp:CreateDate>
      <xmp:ModifyDate>{{ now | format_datetime }}</xmp:ModifyDate>
      <xmp:CreatorTool>vFinance Sideloader (vintage_1074)</xmp:CreatorTool>
      <pl:productCode>{{ productcode }}</pl:productCode>
      <pl:templateKey>{{ template_key | default('') }}</pl:templateKey>
      <pl:vintage>vintage_1074</pl:vintage>
      <pl:locale>{{ locale | default('nl_BE') }}</pl:locale>
      <pl:contractNumber>{{ contract.number | default('') }}</pl:contractNumber>
      {% block xmp_extra %}{% endblock %}
    </rdf:Description>
  </rdf:RDF>
</x:xmpmeta>
